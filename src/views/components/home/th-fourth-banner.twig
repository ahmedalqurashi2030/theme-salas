{# =========================================================
  Tharaa | Quad Banner (Home Component)
  - Compatible with twilight.json path: home.th-fourth-banner
========================================================= #}

{% set mobile_two_columns = component.mobile_two_columns ?? true %}
{% set uniform_height = component.uniform_height ?? true %}
{% set gap = component.gap ?? 16 %}
{% set banners = component.banners ?? [] %}

{% if banners|length %}
  <section class="s-block s-block--banners th-banners th-banners--quad">
    <div class="container">
      <div class="th-banners__grid grid {{ mobile_two_columns ? 'grid-cols-2' : 'grid-cols-1' }} md:grid-cols-2 lg:grid-cols-4" style="--th-gap: {{ gap }}px;">

        {% for banner in banners|slice(0, 4) %}
          {% set img = banner['banners.image'] ?? banner.image ?? null %}
          {% set url = banner['banners.url'] ?? banner.url ?? '' %}
          {% set alt_txt = banner['banners.alt_txt'] ?? banner.alt_txt ?? '' %}

          {% if img and img.url is defined %}
            {% set img = img.url %}
          {% endif %}
          {% if img and img.original is defined %}
            {% set img = img.original %}
          {% endif %}
          {% if url and url.url is defined %}
            {% set url = url.url %}
          {% endif %}
          {% if url and url.value is defined %}
            {% set url = url.value %}
          {% endif %}
          {% if url and url[0] is defined %}
            {% set url = url[0].url ?? url[0].value ?? url %}
          {% endif %}

          {% if img %}
            {% if url %}
              <a href="{{ url }}" class="th-banners__item group block overflow-hidden bg-gray-100 rounded-md {{ uniform_height ? 'aspect-square' : '' }}" aria-label="{{ alt_txt|default('banner-' ~ loop.index) }}">
            {% else %}
              <div class="th-banners__item group block overflow-hidden bg-gray-100 rounded-md {{ uniform_height ? 'aspect-square' : '' }}">
            {% endif %}

            <img class="block w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.03]" src="{{ img }}" alt="{{ alt_txt|default('') }}" loading="{{ loop.first ? 'eager' : 'lazy' }}" decoding="async" fetchpriority="{{ loop.first ? 'high' : 'auto' }}">

            {% if url %}
              </a>
            {% else %}
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
