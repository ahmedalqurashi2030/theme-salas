{#
  Promo Hero Products
  Path: home.promo-hero-products
#}

{% set is_ar = user.language.code starts with 'ar' %}
{% set tr_offer_remaining = trans('pages.offer.offer_remaining_time') %}
{% set tr_offer_finished = trans('pages.offer.offer_finished') %}
{% set tr_included_products = trans('pages.offer.included_products') %}

{% set offer_badge_text = is_ar ? 'عرض محدود' : 'Limited Offer' %}
{% set offer_remaining_text = tr_offer_remaining starts with 'pages.' ? (is_ar ? 'ينتهي العرض خلال' : 'Offer ends in') : tr_offer_remaining %}
{% set offer_finished_text = tr_offer_finished starts with 'pages.' ? (is_ar ? 'انتهى العرض' : 'Offer has ended') : tr_offer_finished %}
{% set included_products_text = tr_included_products starts with 'pages.' ? (is_ar ? 'المنتجات المميزة' : 'Featured products') : tr_included_products %}
{% set timer_days_text = is_ar ? 'يوم' : 'Days' %}
{% set timer_hours_text = is_ar ? 'ساعة' : 'Hr' %}
{% set timer_minutes_text = is_ar ? 'دقيقة' : 'Min' %}
{% set timer_seconds_text = is_ar ? 'ثانية' : 'Sec' %}

{% set title = component.title ?? (is_ar ? 'تسوق بذكاء لوقت محدود' : 'Shop Smart for a Limited Time') %}
{% set description = component.description ?? '' %}
{% set hero_image = component.hero_image ?? null %}
{% set countdown_end = component.countdown_end ?? '' %}
{% set show_countdown_raw = component.show_countdown ?? false %}
{% set show_countdown = show_countdown_raw in [true, 1, '1', 'true'] %}
{% set show_rating_raw = component.show_price ?? true %}
{% set show_rating = show_rating_raw in [true, 1, '1', 'true'] %}
{% set button_text = component.button_text ?? (is_ar ? 'تسوّق الآن' : 'Shop Now') %}
{% set button_link = component.button_link ?? '' %}
{% set products = component.products ?? [] %}
{% set should_scroll_products = products|length > 4 %}
{% set section_id = 'th-promo-hero-' ~ position %}
{% set placeholder_image = theme.settings.get('placeholder', 'images/placeholder.png')|asset %}
{% set hero_image_src = hero_image ? hero_image : placeholder_image %}
{% set empty_products_text = is_ar ? 'لا توجد منتجات مختارة لهذا القسم حالياً.' : 'No selected products for this section yet.' %}

<section class="s-block th-promo-hero th-ui-section {{ should_scroll_products ? 'th-promo-hero--scroll-products' : 'th-promo-hero--grid-products' }}" id="{{ section_id }}" aria-labelledby="{{ section_id }}-title">
  <div class="container">
    <div class="th-promo-hero__shell">
      <header class="th-promo-hero__header">
        <figure class="th-promo-hero__visual">
          <img src="{{ hero_image_src }}"
               alt="{{ title }}"
               class="th-promo-hero__hero-image"
               loading="lazy"
               decoding="async"
               draggable="false">
        </figure>

        <div class="th-promo-hero__content">
          <span class="th-promo-hero__eyebrow">{{ offer_badge_text }}</span>
          <h2 class="th-promo-hero__title" id="{{ section_id }}-title">{{ title }}</h2>

          {% if description %}
            <div class="th-promo-hero__description">{{ description|raw }}</div>
          {% endif %}

          {% if show_countdown and countdown_end %}
            <div class="th-promo-hero__timer-wrap">
              <p class="th-promo-hero__timer-label">{{ offer_remaining_text }}</p>
              <div class="th-promo-hero__timer"
                   data-th-promo-countdown
                   data-end="{{ countdown_end|e('html_attr') }}"
                   data-expired-text="{{ offer_finished_text|e('html_attr') }}"
                   role="timer"
                   aria-live="polite"
                   aria-atomic="true">
                <div class="th-promo-hero__timer-item">
                  <span class="th-promo-hero__timer-value" data-part="days">00</span>
                  <span class="th-promo-hero__timer-unit">{{ timer_days_text }}</span>
                </div>
                <div class="th-promo-hero__timer-item">
                  <span class="th-promo-hero__timer-value" data-part="hours">00</span>
                  <span class="th-promo-hero__timer-unit">{{ timer_hours_text }}</span>
                </div>
                <div class="th-promo-hero__timer-item">
                  <span class="th-promo-hero__timer-value" data-part="minutes">00</span>
                  <span class="th-promo-hero__timer-unit">{{ timer_minutes_text }}</span>
                </div>
                <div class="th-promo-hero__timer-item">
                  <span class="th-promo-hero__timer-value" data-part="seconds">00</span>
                  <span class="th-promo-hero__timer-unit">{{ timer_seconds_text }}</span>
                </div>
              </div>
              <p class="th-promo-hero__timer-expired" data-th-promo-expired hidden>{{ offer_finished_text }}</p>
            </div>
          {% endif %}

          {% if button_text and button_link %}
            <a href="{{ button_link }}" class="btn btn--primary btn--rounded-full th-promo-hero__cta" aria-label="{{ button_text }}">
              <span>{{ button_text }}</span>
              <i class="sicon-keyboard_arrow_{{ user.language.dir == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
            </a>
          {% endif %}
        </div>
      </header>

      <div class="th-promo-hero__products" aria-label="{{ included_products_text }}">
        <p class="th-promo-hero__products-heading">{{ included_products_text }}</p>

        {% if products|length %}
          <div class="th-promo-hero__products-list {{ should_scroll_products ? 'th-promo-hero__products-list--scroll' : 'th-promo-hero__products-list--grid' }}" data-th-promo-products-track>
            {% for product in products %}
              {% set product_id = product.id ?? null %}
              {% set product_url = product.url ?? '#' %}
              {% set product_name = product.name ?? (is_ar ? 'منتج' : 'Product') %}
              {% set product_image = product.image.url ?? product.image ?? placeholder_image %}
              {% set product_image_alt = product.image.alt ?? product_name %}
              {% set product_price = product.sale_price ?? product.price ?? product.regular_price ?? null %}
              {% set product_stars = product.rating.stars ?? product.rating ?? 0 %}
              {% set product_stars = product_stars|round(0, 'floor') %}

              <article class="th-promo-hero__product-card th-ui-card {{ should_scroll_products ? 'th-promo-hero__product-card--scroll' : '' }}">
                <a href="{{ product_url }}" class="th-promo-hero__product-link" aria-label="{{ product_name }}">
                  <span class="th-promo-hero__product-image-wrap">
                    <img src="{{ product_image }}"
                         alt="{{ product_image_alt }}"
                         class="th-promo-hero__product-image"
                         loading="lazy"
                         decoding="async"
                         draggable="false">
                  </span>

                  <span class="th-promo-hero__product-content">
                    <span class="th-promo-hero__product-title">{{ product_name }}</span>
                    {% if show_rating %}
                      <span class="th-promo-hero__rating th-ui-stars" aria-label="{{ is_ar ? ('التقييم ' ~ product_stars ~ ' من 5') : ('Rating ' ~ product_stars ~ ' out of 5') }}">
                        {% for i in 1..5 %}
                          <i class="sicon-star2 {{ i <= product_stars ? 'is-active' : '' }}" aria-hidden="true"></i>
                        {% endfor %}
                      </span>
                    {% endif %}
                    {% if product_price is not null %}
                      <strong class="th-promo-hero__product-price">{{ product_price|money }}</strong>
                    {% endif %}
                  </span>
                </a>

                {% if product_id %}
                  <salla-add-product-button
                    class="th-promo-hero__add-btn"
                    product-id="{{ product_id }}"
                    product-status="{{ product.status ?? '' }}"
                    product-type="{{ product.type ?? '' }}"
                    aria-label="{{ trans('common.add_to_cart') ~ ' ' ~ product_name }}">
                    <span class="sr-only">{{ trans('common.add_to_cart') }}</span>
                    <i class="sicon-shopping-bag" aria-hidden="true"></i>
                  </salla-add-product-button>
                {% endif %}
              </article>
            {% endfor %}
          </div>

          {% if should_scroll_products %}
            <div class="th-promo-hero__scroll-track" data-th-promo-scroll-track aria-hidden="true">
              <span class="th-promo-hero__scroll-thumb" data-th-promo-scroll-thumb></span>
            </div>
          {% endif %}
        {% else %}
          <div class="th-promo-hero__empty th-ui-empty">{{ empty_products_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
