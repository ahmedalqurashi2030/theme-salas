<header id="mainnav" class="store-header th-header">
	<div
		class="inner">
		{# Global announcement bar (inside header, before topbar) #}
		{% include 'components.global.global-announcement' %}

		{# 1. الشريط العلوي #}
		<div class="th-topbar hidden md:block">
			<div class="container flex justify-between items-center">
				<div class="flex items-center gap-4">
					{% component 'footer.menu' with {is_header:true} %}

					{% if store.settings.is_multilingual or store.settings.currencies_enabled %}
						<button type="button" onclick="var modal=document.querySelector('salla-localization-modal'); if(modal){modal.open();}" class="th-topbtn text-xs">
							<span class="flag iti__flag iti__{{ user.language.country_code }}"></span>
							<span>{{ currency.symbol }}</span>
						</button>
					{% endif %}
				</div>
				<div class="text-xs opacity-90 font-medium">
					<i class="sicon-shipping-fast mx-1"></i>
					{{ trans('blocks.header.free_shipping') }}
				</div>
			</div>
		</div>

		{# 2. الهيدر الرئيسي #}
		<div class="th-main-header py-3">
			<div class="container flex items-center justify-between gap-6">
				<a href="#mobile-menu" class="hamburger-btn lg:hidden text-2xl text-gray-800 w-11 h-11 flex items-center justify-center hover:text-primary transition-colors" aria-label="{{ trans('blocks.header.menu') }}">
					<i class="sicon-menu"></i>
				</a>

				<a href="{{ store.url }}" class="store-logo shrink-0" aria-label="{{ store.name }}">
					<img src="{{ store.logo }}" alt="{{ store.name }}" width="192" height="64" loading="eager" decoding="async" class="h-10 md:h-12 w-auto object-contain">
				</a>

				<div class="header-search flex-1 hidden lg:block">
					<salla-search inline placeholder="{{ trans('blocks.header.search_placeholder') }}"></salla-search>
				</div>

				<div class="header-actions flex items-center gap-6">
					{% set tr_open_search = trans('blocks.header.open_search') %}
					{% set open_search_label = tr_open_search starts with 'blocks.' ? 'فتح البحث' : tr_open_search %}
					<button class="lg:hidden text-xl" onclick="salla.event.dispatch('search::open')" aria-label="{{ open_search_label }}">
						<i class="sicon-search"></i>
					</button>

					{% set tr_language = trans('blocks.header.language') %}
					{% set language_label = tr_language starts with 'blocks.' ? 'Language' : tr_language %}
					<button type="button" class="th-lang-switch" aria-label="{{ language_label }}" onclick="var modal=document.querySelector('salla-localization-modal'); if (modal) { modal.open(); }">
						<span class="th-lang-switch__globe" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="9"></circle>
								<path d="M3.6 9h16.8"></path>
								<path d="M3.6 15h16.8"></path>
								<path d="M12 3a13.8 13.8 0 0 1 0 18"></path>
								<path d="M12 3a13.8 13.8 0 0 0 0 18"></path>
							</svg>
						</span>
						<span class="sr-only">{{ language_label }}</span>
					</button>

					{# التأكد من أن المتجر يدعم أكثر من لغة #}


					<div class="hidden lg:block">
						<salla-user-menu avatar-only show-header></salla-user-menu>
					</div>
					<button class="lg:hidden text-xl" onclick="salla.event.dispatch('login::open')" aria-label="{{ trans('blocks.header.login') }}">
						<i class="sicon-user"></i>
					</button>

					{% if user.type=='user' %}
						<a href="{{ link('wishlist') }}" class="th-icon-btn hidden lg:flex" aria-label="{{ trans('blocks.header.wishlist') }}">
							<i class="sicon-heart"></i>
							<span class="th-icon-label">{{ trans('blocks.header.wishlist') }}</span>
						</a>
					{% endif %}

					<div class="th-cart-wrapper flex items-center gap-2">
						<div class="th-cart-total hidden md:flex flex-col items-end leading-tight" data-cart-total>
							<span class="font-bold text-sm">{{ cart.total|money }}</span>
						</div>
						<salla-cart-summary class="th-icon-btn" aria-label="{{ trans('blocks.header.cart') }}">
							<div slot="icon" class="relative">
								<i class="sicon-shopping-bag"></i>
							</div>
						</salla-cart-summary>
					</div>
				</div>
			</div>
		</div>

		{# 3. الناف بار - Desktop Only #}
		<div class="th-navbar hidden lg:block">
			<div class="container h-full">
				{% component 'header.menu' %}
			</div>
		</div>
	</div>
</header>

{# Mobile Menu for mmenu-light in app.js #}
{# Important: use custom-main-menu as the single source for mobile menus,
   because it fetches menu data from Salla API and avoids empty scope issues in header.twig #}
<custom-main-menu class="lg:hidden"></custom-main-menu>

<salla-localization-modal></salla-localization-modal>
{% if store.scope %}
	<salla-scopes></salla-scopes>
{% endif %}
