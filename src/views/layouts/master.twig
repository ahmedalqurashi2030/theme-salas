{# ############## Shared Variables in all views ################
| Variable                                           | Type     | Description                                                                                              |
|----------------------------------------------------|----------|----------------------------------------------------------------------------------------------------------|
| store                                              | Store    |                                                                                                          |
| store.id                                           | int      |                                                                                                          |
| store.name                                         | string   |                                                                                                          |
| store.username                                     | string   |                                                                                                          |
| store.description                                  | string   |                                                                                                          |
| store.slogan                                       | ?string  | * if feature in twilight.json                                                                            |
| store.logo                                         | string   |                                                                                                          |
| store.url                                          | string   |                                                                                                          |
| store.api                                          | string   | the api url for current store                                                                            |
| store.icon                                         | string   | *fav icon url                                                                                            |
| store.contacts                                     | object   | [mobile, phone, email, whatsapp, telegram], ex. store.contacts.email                                     |
| store.social                                       | object   | [instagram, snapchat, twitter, youtube, facebook, pinterest, maroof, whatsapp], ex. store.social.twitter |
| store.settings                                     | object   |                                                                                                          |
| store.settings.auth.email_allowed                  | bool     |                                                                                                          |
| store.settings.auth.mobile_allowed                 | bool     |                                                                                                          |
| store.settings.auth.is_email_required              | bool     |                                                                                                          |
| store.settings.cart.apply_coupon_enabled           | bool     | Does visitor allowed to applay coupon in cart page                                                       |
| store.settings.product.total_sold_enabled          | bool     |                                                                                                          |
| store.settings.product.fit_type                    | ?string  | null when equal product card size is off, or ['cover', 'contain']                                        |
| store.settings.category.testimonial_enabled        | bool     | Show random testimonials in category page                                                                |
| store.settings.tax.number                          | ?string  |                                                                                                          |
| store.settings.tax.certificate                     | ?string  | certificate image url                                                                                    |
| store.settings.tax.taxable_prices_enabled          | bool     | Does tax included in the prices ex product_price 100 & tax is 15, price will be 115                      |
| store.settings.rating_enabled                      | bool     | Is one of: store_enabled or shipping_enabled or products_enabled                                         |
| store.settings.arabic_numbers_enabled              | bool     | Does the merchant wants the numbers to be shown as Arabic format                                         |
| store.settings.is_multilingual                     | bool     |                                                                                                          |
| store.settings.currencies_enabled                  | bool     |     
| theme                                              | Theme    |                                                                                                          |
| theme.id                                           | int      |                                                                                                          |
| theme.name                                         | string   |                                                                                                          |
| theme.mode                                         | string   | `live`, `preview`                                                                                        |
| theme.is_rtl                                       | bool     |                                                                                                          |
| theme.translations_hash                            | int      | to be used in case merchant updated frontend store translations                                          |
| theme.color                                        | object   |                                                                                                          |
| theme.color.primary                                | string   |                                                                                                          |
| theme.color.text                                   | string   | suitable text color comparing to `theme.primary.color`, #000000, #FFFFFF                                 |
| theme.color.reverse_primary                        | string   |                                                                                                          |
| theme.color.reverse_text                           | string   | if `theme.text_color=#000000` means that `theme.reverse_text_color=#FFFFFF`                              |
| theme.color.is_dark                                | bool     | Does main store color `theme.primary.color` considered as dim color?                                     |
| theme.color.darker(float alpha, ?string hexColor)  | string   | get darker color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0             |
| theme.color.lighter(float alpha, ?string hexColor) | string   | get lighter color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0            |
| theme.font                                         | ?object  | Salla predefined font, null when the theme doesn't have `fonts` feature                                  |
| theme.font.name                                    | string   | DINNextLTArabic-Regular, Amazon-Ember, Apple, Dubai, Estedad                                             |
| theme.font.url                                     | string   | css full url ex: 'https://my_store.test/dist/fonts/default.css'                                          |
| theme.settings                                     | object   | dynamic object with values of the `settings` in twilight.json ex. `theme.settings.topnav_is_dark`        |
| theme.settings.set(settingName, value)             | string   | set global var, then get it {{theme.settings.get('my_var','fallback') }}                                 |
| theme.settings.get(settingName, default=null)      | mixed    | get theme setting ex `theme.settings.get('my_var', 'fallback')`                                          |
#}
<!DOCTYPE html>
<html
	lang="{{ user.language.code }}" dir="{{ user.language.dir }}" class="tharaa-theme">
	<!-- بسم الله الرحمن الرحيم -->
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		{{ theme.settings.set('placeholder', 'images/placeholder.png') }}
		{% set desktop_products_per_row_raw = theme.settings.get('desktop_products_per_row', '6') %}
		{% set desktop_products_per_row = desktop_products_per_row_raw.value ?? desktop_products_per_row_raw[0].value ?? desktop_products_per_row_raw %}
		{% set desktop_products_per_row = desktop_products_per_row in ['4', '5', '6', '7', '8', 4, 5, 6, 7, 8] ? desktop_products_per_row : '6' %}
		{% set show_cart_quantity_and_currency_raw = theme.settings.get('show_cart_quantity_and_currency', true) %}
		{% set show_cart_quantity_and_currency_value = show_cart_quantity_and_currency_raw.value ?? show_cart_quantity_and_currency_raw.selected ?? show_cart_quantity_and_currency_raw %}
		{% set show_cart_quantity_and_currency_enabled = show_cart_quantity_and_currency_value in [true, 1, '1', 'true', 'on', 'yes'] %}
		{% set card_show_rating_raw = theme.settings.get('card_show_rating', true) %}
		{% set card_show_discount_badge_raw = theme.settings.get('card_show_discount_badge', true) %}
		{% set card_show_rating_value = card_show_rating_raw.value ?? card_show_rating_raw.selected ?? card_show_rating_raw %}
		{% set card_show_discount_badge_value = card_show_discount_badge_raw.value ?? card_show_discount_badge_raw.selected ?? card_show_discount_badge_raw %}
		{% set card_show_rating_enabled = card_show_rating_value in [true, 1, '1', 'true', 'on', 'yes'] %}
		{% set card_show_discount_badge_enabled = card_show_discount_badge_value in [true, 1, '1', 'true', 'on', 'yes'] %}

		{% include 'pages.partials.loading-screen-assets' %}

		<script defer data-cfasync="false" src="{{ 'product-card.js'|asset }}"></script>
		<script defer src="{{ 'main-menu.js'|asset }}"></script>

		{% block head_scripts %}{% endblock %}

		{% hook 'head:start' %}
		{% hook head %}
		{% block styles %}{% endblock %}
		<link rel="stylesheet" href="{{ 'app.css' | asset }}">
		<link rel="stylesheet" href="{{ theme.font.path|default(theme.font.url)|cdn }}"/>
		<link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>

		<style>:root
		{
			--font-main: '{{ theme.font.name }}';
			--color-primary: {{theme.color.primary}}
			;
			--color-primary-dark: {{theme.color.darker(0.15)}}
			;
			--color-primary-light: {{theme.color.lighter(0.15)}}
			;
			--color-primary-reverse: {{theme.color.reverse_text}}
			;
			--th-color-primary: {{theme.settings.get('primary_brand_color', '#f9b311ff')}}
			;
			/* Runtime theme settings (merchant-controlled from twilight.json settings) */
			--th-bg-main: {{theme.settings.get('main_bg_color', '#ffffff')}}
			;
			--th-bg-secondary: {{theme.settings.get('secondary_bg_color', '#fbfbfb')}}
			;
			--th-text-primary: {{theme.settings.get('primary_text_color', '#111827')}}
			;
			--th-text-secondary: {{theme.settings.get('secondary_text_color', '#111827')}}
			;
			--th-header-bg: {{theme.settings.get('header_bg_color', '#ffffff')}}
			;
			--th-desktop-products-per-row: {{desktop_products_per_row}}
			;

		}
	</style>
	{# tracking services, custom css feature. #}
	{% hook 'head:end' %}
</head>
<body id="app" data-header-is-sticky="{{ theme.settings.get('header_is_sticky', false) ? 'true' : 'false' }}" data-image-zoom="{{ theme.settings.get('imageZoom', false) ? 'true' : 'false' }}" data-can-access-wallet="{{ user.can_access_wallet ? 'true' : 'false' }}" data-show-cart-total="{{ show_cart_quantity_and_currency_enabled ? 'true' : 'false' }}" class="overflow-x-hidden {% hook 'body:classes' %}
																						  {{ theme.settings.get('footer_is_dark') ? ' footer-is-dark' : ' footer-is-light' }}
																						  {{ theme.settings.get('topnav_is_dark') ? ' topnav-is-dark' : '' }}
																						  {{ theme.settings.get('sticky_add_to_cart') ? ' is-sticky-product-bar' : '' }}
																						  {{ card_show_rating_enabled ? '' : ' th-hide-card-rating' }}
																						  {{ card_show_discount_badge_enabled ? '' : ' th-hide-card-discount' }}
																						  ">
	<div class="loader-init"></div>
	<noscript>
		To get full functionality of this site you need to enable JavaScript. Here is how
		<a href="https://www.enable-javascript.com/" rel="noreferrer" target="_blank">To enable JavaScript on webpage</a>.
	</noscript>
	<div class="app-inner flex flex-col min-h-full">
		{% hook 'body:start' %}
		{% component 'header.header' %}
		{% block content %}{% endblock %}
		{% component 'footer.footer' %}
	</div>
	{% hook 'body:end' %}
	<script defer src="{{ 'app.js' | asset }}"></script>
	{# <script defer src="{{ 'partials/thraa-product-card.js' | asset }}"></script> #}
	{# Twilight Components #}
	<salla-offer-modal></salla-offer-modal>
	<salla-search></salla-search>

	{% if user.type=='guest' %}
		<salla-login-modal></salla-login-modal>
	{% endif %}

	{# --- Quick View Modal --- #}
	<div
		id="product-quick-view-modal"
		class="th-quick-view-modal fixed inset-0 z-[100] hidden"
		aria-hidden="true"
		role="dialog"
		aria-modal="true"
		aria-labelledby="product-quick-view-title"
		tabindex="-1">
		{# غلاف شفاف مع إغلاق خارجي #}
		<div class="s-salla-modal-overlay fixed inset-0 bg-slate-900/60 transition-opacity opacity-0 cursor-pointer" data-close-modal="product-quick-view-modal" aria-label="{{ trans('common.close') }}"></div>

		{# الكرت الأساسي، تم وضع transition هنا ليشتغل منه التحريك #}
		<div class="s-salla-modal-body fixed inset-x-0 bottom-0 sm:inset-0 flex items-end sm:items-center justify-center sm:p-4 opacity-0 translate-y-full sm:translate-y-4 sm:scale-95 transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] pointer-events-none">

			<div
				class="th-quick-view-sheet bg-white sm:rounded-3xl rounded-t-3xl shadow-2xl max-w-6xl w-full overflow-hidden flex flex-col sm:max-h-[88vh] max-h-[92vh] pointer-events-auto relative"
				data-quick-view="sheet">

				{# خط سحب في الجوال #}
				<button type="button" class="th-quick-view-drag-handle w-full flex justify-center py-3 sm:hidden" data-quick-view="drag-handle" data-close-modal="product-quick-view-modal" aria-label="{{ trans('common.close') }}">
					<span class="w-12 h-1.5 bg-gray-300 rounded-full pointer-events-none"></span>
				</button>

				<div
					class="th-quick-view-grid flex flex-col md:flex-row-reverse md:items-stretch overflow-y-auto sm:overflow-hidden h-full">

					{# الصورة الكبيرة (نصف الشاشة يمين) #}
					<div class="th-quick-view-media relative w-full md:w-[56%] bg-slate-50 flex flex-col p-5 sm:p-8 shrink-0">
						<div class="th-quick-view-image-wrap flex-1 min-h-[260px] sm:min-h-[360px] flex items-center justify-center px-2">
							<img
								data-quick-view="image"
								src="{{ theme.settings.get('placeholder', 'images/placeholder.png')|asset }}"
								alt=""
								class="w-full h-auto max-h-[520px] object-contain transition-transform duration-500"/>
						</div>

						{# زر الإغلاق الدائري العائم #}
						<button type="button" class="th-quick-view-close absolute top-4 sm:top-5 inset-inline-end-4 sm:inset-inline-end-5 w-10 h-10 rounded-full bg-white/90 backdrop-blur shadow-sm text-slate-500 hover:text-slate-900 hover:bg-white flex items-center justify-center transition-all z-10" data-close-modal="product-quick-view-modal" data-quick-view="close-btn" aria-label="{{ trans('common.close') }}">
							<i class="sicon-close text-xl pointer-events-none"></i>
						</button>

						<div class="th-quick-view-gallery hidden" data-quick-view="gallery" aria-label="{{ trans('pages.products.product_images')|default('Product images') }}"></div>
					</div>

					{# التفاصيل والبيانات (نصف الشاشة يسار) #}
					<div class="th-quick-view-content w-full md:w-[44%] p-5 sm:p-8 shrink-0 flex flex-col bg-white sm:overflow-y-auto shadow-[-4px_0_24px_rgba(0,0,0,0.02)] z-10">

						<div class="th-quick-view-head-row">
							<p data-quick-view="brand" class="text-xs font-bold tracking-widest uppercase text-slate-400"></p>
							<div data-quick-view="badge" class="text-xs"></div>
						</div>

						<h3 id="product-quick-view-title" data-quick-view="title" class="text-xl sm:text-[1.75rem] font-bold text-slate-900 leading-tight mb-2"></h3>

						<div data-quick-view="rating" class="th-quick-view-rating hidden"></div>

						<div class="th-quick-view-price-box">
							<div data-quick-view="price" class="text-2xl sm:text-3xl font-extrabold text-[var(--th-color-primary,var(--color-primary,#C5A059))] tracking-tight"></div>
						</div>

						<div class="th-quick-view-action-icons">
							<button type="button" data-quick-view="wishlist-btn" class="th-quick-view-icon-btn" aria-pressed="false" aria-label="{{ trans('pages.products.add_to_wishlist')|default('Wishlist') }}">
								<i class="sicon-heart text-base pointer-events-none"></i>
								<span class="sr-only">{{ trans('pages.products.add_to_wishlist')|default('Add to wishlist') }}</span>
							</button>
							<button type="button" data-quick-view="share-btn" class="th-quick-view-icon-btn" aria-label="{{ trans('common.share')|default('Share') }}">
								<i class="sicon-share text-base pointer-events-none"></i>
							</button>
						</div>

						<p data-quick-view="tax" class="th-quick-view-tax hidden"></p>
						<p data-quick-view="stock" class="text-sm font-semibold text-rose-600 bg-rose-50 w-fit px-3 py-1 rounded-md mb-2 hidden"></p>
						<div data-quick-view="notify" class="th-quick-view-notify hidden"></div>
						<div data-quick-view="description" class="th-quick-view-description hidden"></div>

						{# أزرار الإجراءات (الأساسية والثانوية) #}
						<div class="th-quick-view-footer mt-auto pt-4">
							<div data-quick-view="add-button" class="th-quick-view-add-slot"></div>
							<div class="th-quick-view-qty" data-quick-view="qty-control" role="group" aria-label="{{ trans('pages.products.quantity')|default('Quantity') }}">
								<button type="button" class="th-quick-view-qty-btn" data-quick-view="qty-plus" aria-label="{{ trans('common.elements.increase_quantity')|default('Increase quantity') }}">+</button>
								<span class="th-quick-view-qty-value" data-quick-view="qty-value">1</span>
								<button type="button" class="th-quick-view-qty-btn" data-quick-view="qty-minus" aria-label="{{ trans('common.elements.decrease_quantity')|default('Decrease quantity') }}">-</button>
							</div>
						</div>

						<a data-quick-view="link" href="#" class="th-quick-view-link">
								<span>{{ trans('pages.products.view_product')|default('عرض التفاصيل الكاملة') }}</span>
								<i class="sicon-arrow-left2 text-xs rtl:hidden mt-0.5"></i>
								<i class="sicon-arrow-right2 text-xs hidden rtl:inline-block mt-0.5"></i>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	{% block scripts %}
		<script src="{{ 'custom/th-links.js' | asset }}" defer></script>

	{% endblock %}
</body></html>

